{"id": "006", "audio_path": "D:\\dev\\omnivoice-voice-clone-kit\\omnivoice-kit\\data\\raw\\raw\\audio\\006.wav", "text": "Chiếc xe máy đỏ đứng trước cửa nhà từ lúc bây giờ.", "language_id": "vi"}
{"id": "015", "audio_path": "D:\\dev\\omnivoice-voice-clone-kit\\omnivoice-kit\\data\\raw\\raw\\audio\\015.wav", "text": "Tôi đã kiểm tra lại văn bản để tránh lỗi chính tả.", "language_id": "vi"}
{"id": "005", "audio_path": "D:\\dev\\omnivoice-voice-clone-kit\\omnivoice-kit\\data\\raw\\raw\\audio\\005.wav", "text": "Nếu bạn sẵn sàng, chúng ta bắt đầu ghi âm từ câu đầu tiên.", "language_id": "vi"}
{"id": "010", "audio_path": "D:\\dev\\omnivoice-voice-clone-kit\\omnivoice-kit\\data\\raw\\raw\\audio\\010.wav", "text": "Tôi muốn giọng nói tạo ra nghe ấm áp và thân thiện.", "language_id": "vi"}
{"id": "014", "audio_path": "D:\\dev\\omnivoice-voice-clone-kit\\omnivoice-kit\\data\\raw\\raw\\audio\\014.wav", "text": "Hệ thống đang xử lý dữ liệu, vui lòng đợi trong giây lát.", "language_id": "vi"}
{"id": "016", "audio_path": "D:\\dev\\omnivoice-voice-clone-kit\\omnivoice-kit\\data\\raw\\raw\\audio\\016.wav", "text": "Con mèo trắng đang ngủ ngon trên ghế sofa.", "language_id": "vi"}
{"id": "019", "audio_path": "D:\\dev\\omnivoice-voice-clone-kit\\omnivoice-kit\\data\\raw\\raw\\audio\\019.wav", "text": "Cảm ơn bạn đã dành thời gian hỗ trợ tôi hoàn thành công việc.", "language_id": "vi"}
{"id": "007", "audio_path": "D:\\dev\\omnivoice-voice-clone-kit\\omnivoice-kit\\data\\raw\\raw\\audio\\007.wav", "text": "Ngày mai tôi sẽ đến văn phòng sớm hơn mười phút.", "language_id": "vi"}
{"id": "013", "audio_path": "D:\\dev\\omnivoice-voice-clone-kit\\omnivoice-kit\\data\\raw\\raw\\audio\\013.wav", "text": "Giá trị đơn hàng hôm nay là một trăm hai mươi nghìn đồng.", "language_id": "vi"}
{"id": "018", "audio_path": "D:\\dev\\omnivoice-voice-clone-kit\\omnivoice-kit\\data\\raw\\raw\\audio\\018.wav", "text": "Thời tiết mùa này thay đổi rất nhanh, bạn nhớ mang áo khoác.", "language_id": "vi"}
{"id": "011", "audio_path": "D:\\dev\\omnivoice-voice-clone-kit\\omnivoice-kit\\data\\raw\\raw\\audio\\011.wav", "text": "Trong tuần này, dự án cần hoàn tất trước thứ Sáu.", "language_id": "vi"}
{"id": "002", "audio_path": "D:\\dev\\omnivoice-voice-clone-kit\\omnivoice-kit\\data\\raw\\raw\\audio\\002.wav", "text": "Tôi đang thử nghiệm mô hình chuyển đổi văn bản thành giọng nói.", "language_id": "vi"}
{"id": "012", "audio_path": "D:\\dev\\omnivoice-voice-clone-kit\\omnivoice-kit\\data\\raw\\raw\\audio\\012.wav", "text": "Bạn nhớ tắt quạt trước khi rời khỏi căn phòng nhé.", "language_id": "vi"}
{"id": "003", "audio_path": "D:\\dev\\omnivoice-voice-clone-kit\\omnivoice-kit\\data\\raw\\raw\\audio\\003.wav", "text": "Bạn có thể nghe rõ từng chữ trong câu nói này không?", "language_id": "vi"}
{"id": "017", "audio_path": "D:\\dev\\omnivoice-voice-clone-kit\\omnivoice-kit\\data\\raw\\raw\\audio\\017.wav", "text": "Chúng ta sẽ họp lúc chín giờ ba mươi sáng thứ Hai.", "language_id": "vi"}
{"id": "008", "audio_path": "D:\\dev\\omnivoice-voice-clone-kit\\omnivoice-kit\\data\\raw\\raw\\audio\\008.wav", "text": "Âm thanh trong phòng này khá yên tĩnh và ít tiếng ồn.", "language_id": "vi"}
{"id": "009", "audio_path": "D:\\dev\\omnivoice-voice-clone-kit\\omnivoice-kit\\data\\raw\\raw\\audio\\009.wav", "text": "Hãy đọc chậm, rõ ràng, và giữ nhịp điệu tự nhiên.", "language_id": "vi"}
{"id": "001", "audio_path": "D:\\dev\\omnivoice-voice-clone-kit\\omnivoice-kit\\data\\raw\\raw\\audio\\001.wav", "text": "Xin chào, hôm nay trời đẹp và tôi rất vui được ghi âm.", "language_id": "vi"}
{"id": "004", "audio_path": "D:\\dev\\omnivoice-voice-clone-kit\\omnivoice-kit\\data\\raw\\raw\\audio\\004.wav", "text": "Buổi sáng, tôi thường uống một ly nước ấm trước khi làm việc.", "language_id": "vi"}
